def bce2d_new(input, target, reduction=None):
    assert (input.size() == target.size())
    pos = torch.eq(target, 1).float()
    neg = torch.eq(target, 0).float()

    num_pos = torch.sum(pos)
    num_neg = torch.sum(neg)
    num_total = num_pos + num_neg

    alpha = num_neg / num_total
    beta = 1.1 * num_pos / num_total
    weights = alpha * pos + beta * neg

    return F.binary_cross_entropy_with_logits(input, target, weights, reduction=reduction)


def test(test_loader, model, epoch, save_path):
    global best_mae, best_epoch
    model.eval()
    with torch.no_grad():
        # 推理时也开启 autocast
        with torch.cuda.amp.autocast():
            mae_sum = 0.0
            total_num = 0
            for i, (images, gt_paths, names) in enumerate(test_loader):
                images = images.cuda()
                res = model(images)

                for j in range(images.size(0)):
                    gt = Image.open(gt_paths[j]).convert('L')

                    gt = np.asarray(gt, np.float32)
                    gt /= (gt.max() + 1e-8)

                    res_j = res[j].unsqueeze(0)
                    res_j = nn.functional.interpolate(res_j, size=gt.shape, mode='bilinear', align_corners=False)
                    res_j = res_j.sigmoid().detach().cpu().numpy().squeeze()
                    res_j = (res_j - res_j.min()) / (res_j.max() - res_j.min() + 1e-8)

                    mae_sum += np.sum(np.abs(res_j - gt)) * 1.0 / (gt.shape[0] * gt.shape[1])
                    total_num += 1

        # 计算整个测试集的平均 MAE
        mae = mae_sum / total_num
        writer.add_scalar('MAE', mae, global_step=epoch)
        print('Epoch: {} MAE: {} ####  bestMAE: {} bestEpoch: {}'.format(epoch, mae, best_mae, best_epoch))

        if epoch == 1:
            best_mae = mae
            best_epoch = epoch
        else:
            if mae < best_mae:
                best_mae = mae
                best_epoch = epoch
                torch.save(model.state_dict(), save_path + 'Net_epoch_best.pth')
                print('best epoch:{}'.format(epoch))
        logging.info('#TEST#:Epoch:{} MAE:{} bestEpoch:{} bestMAE:{}'.format(epoch, mae, best_epoch, best_mae))

